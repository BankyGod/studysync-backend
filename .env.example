PORT=3000
JWT_SECRET=change-me-in-production
MONGODB_URI=mongodb://127.0.0.1:27017/studysync
# Comma-separated list for multiple frontends (e.g. local + Vercel)
CORS_ORIGIN=http://localhost:5173
# Public API base URL for absolute avatar links (required when frontend is on another host)
PUBLIC_API_URL=http://localhost:3000
UPLOADS_DIR=./uploads
