// StudySync — MongoDB schema (documentation only)
// Paste into https://dbdiagram.io to visualize
// Source of truth for the running app: src/db/models.js
// IDs are UUID strings in production (shown as varchar here)

Table users {
  id varchar [primary key, note: 'MongoDB collection: users']
  email varchar [unique, not null]
  password_hash varchar [not null]
  first_name varchar [not null]
  last_name varchar [not null]
  student_id varchar [unique, not null]
  phone varchar
  university varchar [not null]
  program varchar [not null]
  level varchar [not null, note: '100 | 200 | 300 | 400']
  role varchar [not null, note: 'student | instructor']
  created_at varchar [not null, note: 'ISO-8601']
  updated_at varchar [not null, note: 'ISO-8601']
}

Table user_profiles {
  user_id varchar [primary key, note: 'MongoDB collection: user_profiles']
  full_name varchar [not null]
  student_role varchar
  primary_university varchar
  secondary_university varchar
  location varchar
  avatar_storage_key varchar
  avatar_mime_type varchar
  updated_at varchar [not null]
}

Table onboarding_profiles {
  user_id varchar [primary key, note: 'MongoDB collection: onboarding_profiles']
  learning_style varchar [not null, note: 'visual | auditory | reading | kinesthetic']
  availability varchar [not null, note: 'JSON array of slots, e.g. Mon-8 AM']
  study_preferences varchar [not null, note: 'JSON: groupSize, timeCommitment, difficulty']
  completed_at varchar
  saved_at varchar [not null]
}

Table user_courses {
  id varchar [primary key, note: 'MongoDB collection: user_courses']
  user_id varchar [not null]
  subject varchar [not null]
  course_number varchar [not null]
  is_primary int [note: '1 = primary course, 0 = secondary']
}

Table cohorts {
  id varchar [primary key, note: 'MongoDB collection: cohorts']
  name varchar [not null]
  term varchar
  created_at varchar [not null]
}

Table study_groups {
  id varchar [primary key, note: 'MongoDB collection: study_groups']
  slug varchar [unique, not null, note: 'URL slug, e.g. biology-101']
  title varchar [not null]
  subject varchar [not null]
  course_number varchar [not null]
  cohort_id varchar
  created_at varchar [not null]
}

Table group_members {
  group_id varchar [not null]
  user_id varchar [not null]
  joined_at varchar [not null]
  initials varchar [not null]
  avatar_color varchar [not null, note: 'e.g. bg-sky-500']

  indexes {
    (group_id, user_id) [unique]
  }
}

Table tasks {
  id varchar [primary key, note: 'MongoDB collection: tasks']
  group_id varchar [not null]
  creator_id varchar
  title varchar [not null]
  status varchar [not null, note: 'todo | in_progress | completed']
  progress varchar [note: 'not_started | started | done']
  variant varchar [note: 'default | highlight | completed']
  due_date varchar [note: 'YYYY-MM-DD']
  completed_at varchar
  started_at varchar
  assignee_id varchar
  position int
  created_at varchar [not null]
}

Table task_move_requests {
  id varchar [primary key, note: 'MongoDB collection: task_move_requests — regress approval']
  task_id varchar [not null]
  group_id varchar [not null]
  requester_id varchar [not null]
  from_status varchar [not null]
  target_status varchar [not null]
  status varchar [not null, note: 'pending | approved | denied | rejected']
  resolved_at varchar
  resolved_by_id varchar
  created_at varchar [not null]
}

Table stored_files {
  id varchar [primary key, note: 'MongoDB collection: stored_files — shared pod files']
  group_id varchar [not null]
  uploaded_by_id varchar [not null]
  file_name varchar [not null]
  file_size int [not null]
  file_type varchar [not null, note: 'MIME type']
  storage_key varchar [not null, note: 'Path on disk or blob key']
  source varchar [note: 'chat | files']
  purpose varchar [note: 'legacy: shared | chat_attachment | voice']
  uploaded_at varchar [not null]
}

Table messages {
  id varchar [primary key, note: 'MongoDB collection: messages']
  group_id varchar [not null]
  sender_id varchar [not null]
  type varchar [not null, note: 'text | attachment | voice']
  content varchar [not null]
  file_id varchar [note: 'FK → stored_files when type = attachment']
  voice_duration_sec int
  voice_storage_key varchar [note: 'Voice-only; not in stored_files']
  voice_file_name varchar
  voice_file_type varchar
  voice_file_size int
  sent_at varchar [not null]
}

Table scheduled_sessions {
  id varchar [primary key, note: 'MongoDB collection: scheduled_sessions']
  group_id varchar [not null]
  title varchar [not null]
  date varchar [not null, note: 'YYYY-MM-DD']
  start_time varchar [not null, note: 'HH:mm 24h']
  end_time varchar [not null]
  meeting_type varchar [not null, note: 'Online Meeting | In Person | Hybrid']
  agenda varchar
  created_by_id varchar
  created_at varchar [not null]
}

Table notifications {
  id varchar [primary key, note: 'MongoDB collection: notifications']
  user_id varchar [not null]
  type varchar [not null]
  title varchar [not null]
  message varchar [not null]
  group_id varchar
  group_slug varchar
  task_id varchar
  actor_id varchar
  read_at varchar
  created_at varchar [not null]
  metadata varchar [note: 'JSON object']
}

Table matching_jobs {
  id varchar [primary key, note: 'MongoDB collection: matching_jobs']
  user_id varchar [not null]
  course_subject varchar [not null]
  course_number varchar [not null]
  status varchar [not null, note: 'pending | running | waiting | completed | failed']
  progress int
  current_step varchar
  result_group_id varchar
  error_message varchar
  error_code varchar
  created_at varchar [not null]
  completed_at varchar
}

// ——— Relationships ———

Ref user_profile: user_profiles.user_id - users.id

Ref user_onboarding: onboarding_profiles.user_id - users.id

Ref user_courses_user: user_courses.user_id > users.id

Ref group_cohort: study_groups.cohort_id > cohorts.id

Ref member_group: group_members.group_id > study_groups.id
Ref member_user: group_members.user_id > users.id

Ref task_group: tasks.group_id > study_groups.id
Ref task_creator: tasks.creator_id > users.id
Ref task_assignee: tasks.assignee_id > users.id

Ref regress_task: task_move_requests.task_id > tasks.id
Ref regress_group: task_move_requests.group_id > study_groups.id
Ref regress_requester: task_move_requests.requester_id > users.id
Ref regress_resolver: task_move_requests.resolved_by_id > users.id

Ref file_group: stored_files.group_id > study_groups.id
Ref file_uploader: stored_files.uploaded_by_id > users.id

Ref message_group: messages.group_id > study_groups.id
Ref message_sender: messages.sender_id > users.id
Ref message_attachment: messages.file_id > stored_files.id

Ref session_group: scheduled_sessions.group_id > study_groups.id
Ref session_creator: scheduled_sessions.created_by_id > users.id

Ref notification_user: notifications.user_id > users.id
Ref notification_actor: notifications.actor_id > users.id
Ref notification_task: notifications.task_id > tasks.id
Ref notification_group: notifications.group_id > study_groups.id

Ref matching_user: matching_jobs.user_id > users.id
Ref matching_result_group: matching_jobs.result_group_id > study_groups.id

// ——— Sample records (illustrative) ———

